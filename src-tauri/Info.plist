<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Shown in the macOS microphone-permission prompt the first time
         voice dictation starts. Tauri merges this file into the generated
         app bundle Info.plist on macOS. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Ekorbia uses the microphone for on-device voice dictation. Audio is transcribed locally with Whisper and never leaves your machine.</string>
</dict>
</plist>

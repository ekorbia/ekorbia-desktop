# ── Rust / Cargo ──────────────────────────────────────────────
# Compiled build artifacts. Cargo.lock IS committed (this is a binary
# crate, not a library) so reproducible builds across machines work.
target/
**/*.rs.bk

# ── Tauri ─────────────────────────────────────────────────────
# Auto-generated by tauri-build at compile time; checked in copies
# would drift from the actual build.
src-tauri/gen/
src-tauri/WixTools/

# Bundle output from `cargo tauri build`
src-tauri/target/release/bundle/

# ── Frontend (CDN-based React; here in case a bundler is added later) ──
# node_modules/ exists ONLY for Playwright test tooling — production UI
# is no-bundler / no-npm (see CLAUDE.md). Don't ship it.
node_modules/
ui/dist/
ui/.parcel-cache/

# ── Playwright (UI test runner) ────────────────────────────────
# Trace files, screenshots, videos, HTML reports — all regeneratable
# from a re-run. The fixtures + .spec.js files under tests/e2e/ ARE
# committed.
test-results/
playwright-report/
playwright/.cache/

# ── mdBook (user docs) ────────────────────────────────────────
# Markdown sources in docs/src/ + theme overrides in docs/theme/ ARE
# committed. The rendered HTML in docs/book/ is built fresh from
# `./scripts/build-docs.sh` before manual upload to the website.
docs/book/

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?

# ── Editors / IDEs ────────────────────────────────────────────
.vscode/
.idea/
.zed/
*.swp
*.swo
*~

# ── Logs & misc ───────────────────────────────────────────────
*.log
npm-debug.log*

# ── Environment / secrets ─────────────────────────────────────
.env
.env.local
.env.*.local

# ── Local app data (in case anything ever lands in-tree) ──────
# The real SQLite DB lives in macOS's app data dir, not in the repo,
# but ignore here defensively in case anything is tested in-place.
*.db
*.db-shm
*.db-wal
